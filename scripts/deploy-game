#!/bin/bash
set -e

DEPLOY_SRC="${1:-/tmp/game-deploy}"
DEPLOY_DIR=/var/www/game

# Self-update: if the bundle contains a newer version, install and re-exec
BUNDLE_SCRIPT="$DEPLOY_SRC/scripts/deploy-game"
if [ -f "$BUNDLE_SCRIPT" ] && ! diff -q /usr/local/bin/deploy-game "$BUNDLE_SCRIPT" > /dev/null 2>&1; then
    echo "[deploy] Updating deploy script from bundle..."
    install -m 755 "$BUNDLE_SCRIPT" /usr/local/bin/deploy-game
    exec /usr/local/bin/deploy-game "$@"
fi

# Read service user dynamically from systemd (never hardcode www-data)
SERVICE_USER=$(systemctl show game --property=User --value)
SERVICE_GROUP=$(systemctl show game --property=Group --value)

if [ -z "$SERVICE_USER" ]; then
    echo "[deploy] ERROR: Could not read User from game.service"
    exit 1
fi

echo "[deploy] Stopping service..."
systemctl stop game || true

echo "[deploy] Installing binary..."
rm -f "$DEPLOY_DIR/game"
cp "$DEPLOY_SRC/game" "$DEPLOY_DIR/game"
chmod +x "$DEPLOY_DIR/game"

echo "[deploy] Updating web assets..."
for dir in sql templates static; do
    if [ -d "$DEPLOY_SRC/$dir" ]; then
        rm -rf "$DEPLOY_DIR/$dir"
        cp -r "$DEPLOY_SRC/$dir" "$DEPLOY_DIR/$dir"
    fi
done
chown -R "$SERVICE_USER:$SERVICE_GROUP" "$DEPLOY_DIR"

echo "[deploy] Starting service..."
systemctl start game

echo "[deploy] Verifying service is active..."
sleep 2
if ! systemctl is-active --quiet game; then
    echo "[deploy] ERROR: Service failed to start. Status:"
    systemctl status game --no-pager --lines=30
    exit 1
fi

echo "[deploy] Cleaning up..."
rm -rf "$DEPLOY_SRC"

echo "[deploy] Done — game is running."
